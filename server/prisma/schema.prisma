datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  username      String   @unique
  password      String // Hashed password
  salt          String // Bcrypt salt
  role          UserRole @default(INVESTOR)
  walletBalance Float    @default(10000.00) // Starting virtual cash
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trades            Trade[]
  channels          Channel[] // Channels claimed by this creator
  portfolios        Portfolio[]
  watchlistChannels Channel[]   @relation("UserWatchlist")
  notifications     Notification[]
}

enum UserRole {
  INVESTOR
  CREATOR
  ADMIN
}

model Channel {
  id           String  @id // YouTube Channel ID
  name         String
  handle       String  @unique
  logo         String?
  currentPrice Float
  ipoPrice     Float

  // Algorithm Fundamentals
  creatorScore      Float
  growthScore       Float
  engagementScore   Float
  consistencyScore  Float
  momentumScore     Float
  marketDemandScore Float

  subscriberCount Float
  viewCount       Float
  videoCount      Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId      String?
  owner        User?          @relation(fields: [ownerId], references: [id])
  trades       Trade[]
  shareholders Portfolio[]
  priceHistory PriceHistory[]
  snapshots    ChannelSnapshot[]
  watchers     User[]         @relation("UserWatchlist")

  isApproved      Boolean @default(false)
  isTradingPaused Boolean @default(false)
}

model Portfolio {
  id              String @id @default(uuid())
  userId          String
  channelId       String
  sharesOwned     Int    @default(0) // Must remain >= 0
  averageBuyPrice Float  @default(0.0)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
}

model Trade {
  id        String    @id @default(uuid())
  userId    String
  channelId String
  type      TradeType
  shares    Int // Number of shares
  price     Float // Execution share price
  createdAt DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id])
  channel Channel @relation(fields: [channelId], references: [id])
}

enum TradeType {
  BUY
  SELL
}

model PriceHistory {
  id           Int      @id @default(autoincrement())
  channelId    String
  price        Float
  creatorScore Float
  createdAt    DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model ChannelSnapshot {
  id              Int      @id @default(autoincrement())
  channelId       String
  subscriberCount Float
  viewCount       Float
  creatorScore    Float
  stockPrice      Float
  createdAt       DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
